---
import Where from "./where.astro";
import Music from "./music.astro";
---

<main>
  <section class="mt-24">
    <div
      class="animate-intro relative left-1/2 flex w-[min(1024px,95vw)] -translate-x-1/2 flex-col gap-3 opacity-0 [animation-delay:0.4s] select-none"
    >
      <div class="flex flex-col gap-3 sm:grid sm:aspect-square sm:grid-cols-4 sm:grid-rows-4">
        <div class="grid grid-cols-2 gap-3 sm:contents">
          <div class="sm:col-start-1 sm:row-start-1">
            <Where />
          </div>
          <div class="sm:col-start-2 sm:row-start-1">
            <Music />
          </div>
        </div>
        <a
          href="https://kmenu.dev"
          target="_blank"
          rel="noreferrer"
          class="exclude relative block aspect-square overflow-hidden rounded-2xl border border-neutral-200 dark:border-neutral-700 sm:col-span-2 sm:col-start-3 sm:row-span-2 sm:row-start-1"
        >
          <video
            src="/bento/kmenu.mp4"
            autoplay
            loop
            muted
            playsinline
            preload="auto"
            class="absolute inset-0 h-full w-full object-cover"
          ></video>
          <div
            aria-hidden="true"
            class="fade-to-bottom-soft pointer-events-none absolute inset-x-0 bottom-0 h-1/3"
          >
          </div>
          <div
            class="pointer-events-none absolute inset-x-0 bottom-0 mb-3 mx-2 flex items-baseline justify-between gap-2 px-2 text-white"
          >
            <span class="flex items-center gap-0.5 text-sm font-medium">
              kmenu
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
                class="translate-y-px"
              >
                <path
                  d="m19 15.477-.02-9.672a.802.802 0 0 0-.218-.577c-.145-.152-.34-.228-.587-.228H8.499a.751.751 0 0 0-.777.76c0 .199.076.371.227.517.15.145.326.218.525.218h3.733l4.52-.129-1.728 1.54-9.767 9.783a.692.692 0 0 0-.232.518c0 .205.078.387.235.545a.74.74 0 0 0 .542.237.73.73 0 0 0 .527-.224l9.775-9.78 1.544-1.727-.143 4.188v4.065c0 .199.075.376.225.531.15.155.327.232.531.232.202 0 .38-.076.534-.228a.768.768 0 0 0 .23-.569Z"
                  fill="currentColor"
                />
              </svg>
            </span>
            <span class="shrink-0 text-sm text-neutral-300">2022</span>
          </div>
        </a>
        <div
          class="relative aspect-[2/1] overflow-hidden rounded-2xl border border-neutral-200 bg-white dark:border-neutral-700 dark:bg-neutral-900 sm:aspect-auto sm:col-span-2 sm:col-start-1 sm:row-start-2"
        >
          <video
            src="/bento/qr.mp4"
            autoplay
            loop
            muted
            playsinline
            preload="auto"
            class="absolute inset-0 h-full w-full object-cover"
          ></video>
        </div>
        <div
          class="relative aspect-square overflow-hidden rounded-2xl border border-neutral-200 bg-white dark:border-neutral-700 dark:bg-neutral-900 sm:col-span-2 sm:col-start-1 sm:row-span-2 sm:row-start-3"
        >
          <video
            src="/bento/modal.mp4"
            autoplay
            loop
            muted
            playsinline
            preload="auto"
            class="absolute inset-0 h-full w-full object-cover"
          ></video>
        </div>
        <a
          href="https://snip.tf"
          target="_blank"
          rel="noreferrer"
          class="exclude relative block aspect-square overflow-hidden rounded-2xl border border-neutral-200 dark:border-neutral-700 sm:col-start-3 sm:row-start-3"
        >
          <img
            src="/bento/snip.webp"
            alt=""
            draggable="false"
            loading="lazy"
            class="absolute inset-0 h-full w-full object-cover"
          />
          <div
            aria-hidden="true"
            class="fade-to-bottom pointer-events-none absolute inset-x-0 bottom-0 h-1/3"
          >
          </div>
          <div
            class="pointer-events-none absolute inset-x-0 bottom-0 mb-3 mx-2 flex items-baseline justify-between gap-2 px-2 text-white"
          >
            <span class="flex items-center gap-0.5 text-sm font-medium">
              Snip
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
                class="translate-y-px"
              >
                <path
                  d="m19 15.477-.02-9.672a.802.802 0 0 0-.218-.577c-.145-.152-.34-.228-.587-.228H8.499a.751.751 0 0 0-.777.76c0 .199.076.371.227.517.15.145.326.218.525.218h3.733l4.52-.129-1.728 1.54-9.767 9.783a.692.692 0 0 0-.232.518c0 .205.078.387.235.545a.74.74 0 0 0 .542.237.73.73 0 0 0 .527-.224l9.775-9.78 1.544-1.727-.143 4.188v4.065c0 .199.075.376.225.531.15.155.327.232.531.232.202 0 .38-.076.534-.228a.768.768 0 0 0 .23-.569Z"
                  fill="currentColor"
                />
              </svg>
            </span>
            <span class="shrink-0 text-sm text-neutral-300">2020</span>
          </div>
        </a>
        <a
          href="https://qursor.harshsingh.me"
          target="_blank"
          rel="noreferrer"
          class="exclude relative block aspect-square overflow-hidden rounded-2xl border border-neutral-200 dark:border-neutral-700 sm:col-start-3 sm:row-start-4"
        >
          <video
            src="/bento/qursor.mp4"
            autoplay
            loop
            muted
            playsinline
            preload="auto"
            class="absolute inset-0 h-full w-full object-cover"
          ></video>
          <div
            class="pointer-events-none absolute inset-x-0 bottom-0 mb-3 mx-2 flex items-baseline justify-between gap-2 px-2 text-white"
          >
            <span class="flex items-center gap-0.5 text-sm font-medium">
              Qursor
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
                class="translate-y-px"
              >
                <path
                  d="m19 15.477-.02-9.672a.802.802 0 0 0-.218-.577c-.145-.152-.34-.228-.587-.228H8.499a.751.751 0 0 0-.777.76c0 .199.076.371.227.517.15.145.326.218.525.218h3.733l4.52-.129-1.728 1.54-9.767 9.783a.692.692 0 0 0-.232.518c0 .205.078.387.235.545a.74.74 0 0 0 .542.237.73.73 0 0 0 .527-.224l9.775-9.78 1.544-1.727-.143 4.188v4.065c0 .199.075.376.225.531.15.155.327.232.531.232.202 0 .38-.076.534-.228a.768.768 0 0 0 .23-.569Z"
                  fill="currentColor"
                />
              </svg>
            </span>
            <span class="shrink-0 text-sm text-neutral-300">2021</span>
          </div>
        </a>
        <a
          href="https://dots.harshsingh.me"
          target="_blank"
          rel="noreferrer"
          class="exclude relative block aspect-square overflow-hidden rounded-2xl border border-neutral-200 dark:border-neutral-700 sm:aspect-auto sm:col-start-4 sm:row-span-2 sm:row-start-3"
        >
          <video
            src="/bento/arch.mp4"
            autoplay
            loop
            muted
            playsinline
            preload="auto"
            class="absolute inset-0 h-full w-full object-cover"
          ></video>
          <div
            class="pointer-events-none absolute inset-x-0 bottom-0 mx-2 mb-3 flex items-baseline justify-between gap-2 px-2 text-white"
          >
            <span class="flex items-center gap-0.5 text-sm font-medium">
              ~/.dotfiles
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
                class="translate-y-px"
              >
                <path
                  d="m19 15.477-.02-9.672a.802.802 0 0 0-.218-.577c-.145-.152-.34-.228-.587-.228H8.499a.751.751 0 0 0-.777.76c0 .199.076.371.227.517.15.145.326.218.525.218h3.733l4.52-.129-1.728 1.54-9.767 9.783a.692.692 0 0 0-.232.518c0 .205.078.387.235.545a.74.74 0 0 0 .542.237.73.73 0 0 0 .527-.224l9.775-9.78 1.544-1.727-.143 4.188v4.065c0 .199.075.376.225.531.15.155.327.232.531.232.202 0 .38-.076.534-.228a.768.768 0 0 0 .23-.569Z"
                  fill="currentColor"
                />
              </svg>
            </span>
            <span class="shrink-0 text-sm text-neutral-300">2020</span>
          </div>
        </a>
      </div>
      <div class="flex flex-col gap-3 sm:grid sm:grid-cols-2 sm:grid-flow-col sm:[grid-template-rows:repeat(5,auto)]">
        <div
          class="relative aspect-[2/1] overflow-hidden rounded-2xl border border-neutral-200 bg-[#FAFAFA] dark:border-neutral-700"
        >
          <video
            src="/bento/dynamic-island.mp4"
            autoplay
            loop
            muted
            playsinline
            preload="auto"
            class="absolute inset-0 h-full w-full object-cover translate-x-1 object-[0%_30%]"
          ></video>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div
            class="aspect-square overflow-hidden rounded-2xl border border-neutral-200 bg-white pl-1.5 dark:border-neutral-700"
          >
            <video
              src="/bento/cmdk.mp4"
              autoplay
              loop
              muted
              playsinline
              preload="auto"
              class="h-full w-full object-cover"
            ></video>
          </div>
          <div
            class="flex aspect-square flex-col overflow-hidden rounded-2xl border border-neutral-200 bg-white pb-1 dark:border-neutral-700 dark:bg-neutral-900"
          >
            <div class="relative flex-1 overflow-hidden border-b border-b-neutral-200 dark:border-b-neutral-700">
              <img
                src="/bento/blog_post_1.webp"
                alt=""
                draggable="false"
                class="h-full w-full object-cover"
              />
              <div
                aria-hidden="true"
                class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-white via-white/80 to-transparent dark:from-neutral-900 dark:via-neutral-900/80"
              >
              </div>
              <div
                class="pointer-events-none absolute inset-x-0 bottom-0 flex items-baseline justify-between gap-2 px-2.5 pb-2"
              >
                <p
                  class="truncate text-sm font-medium text-neutral-900 dark:text-neutral-50"
                >
                  Best Distros for Ricing
                </p>
                <p
                  class="shrink-0 text-sm text-neutral-500 dark:text-neutral-400"
                >
                  2024
                </p>
              </div>
            </div>
            <a
              href="/ricing"
              class="exclude mt-1 flex items-center justify-center rounded-xl bg-neutral-200 px-3 mx-1 py-2 text-sm font-medium text-neutral-900 transition-colors hover:bg-neutral-300 dark:bg-neutral-800 dark:text-neutral-50 dark:hover:bg-neutral-700"
            >
              Read Essay
            </a>
          </div>
        </div>
        <div
          aria-hidden="true"
          class="flex aspect-square items-center justify-center rounded-2xl bg-neutral-200 text-3xl font-medium text-neutral-400 dark:bg-neutral-800 dark:text-neutral-600 sm:aspect-auto sm:row-span-2"
        >
          13
        </div>
        <div
          class="relative aspect-[2/1] overflow-hidden rounded-2xl border border-yellow-600 bg-white dark:border-yellow-600 dark:bg-neutral-900"
        >
          <video
            src="/bento/cards.mp4"
            autoplay
            loop
            muted
            playsinline
            preload="auto"
            class="absolute inset-0 h-full w-full object-cover object-center"
          ></video>
        </div>
        <a
          href="https://loomix.harshsingh.me"
          target="_blank"
          rel="noreferrer"
          class="exclude relative block aspect-square overflow-hidden rounded-2xl border border-neutral-200 bg-white dark:border-neutral-700 dark:bg-neutral-900 sm:aspect-auto sm:row-span-2"
        >
          <video
            src="/bento/loomix.mp4"
            autoplay
            loop
            muted
            playsinline
            preload="auto"
            class="absolute inset-0 h-full w-full object-cover"
          ></video>
          <div
            aria-hidden="true"
            class="fade-to-bottom-soft pointer-events-none absolute inset-x-0 bottom-0 h-1/3"
          >
          </div>
          <div
            class="pointer-events-none absolute inset-x-0 bottom-0 mb-3 mx-2 flex items-baseline justify-between gap-2 px-2 text-white"
          >
            <span class="flex items-center gap-0.5 text-sm font-medium">
              Loomix
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
                class="translate-y-px"
              >
                <path
                  d="m19 15.477-.02-9.672a.802.802 0 0 0-.218-.577c-.145-.152-.34-.228-.587-.228H8.499a.751.751 0 0 0-.777.76c0 .199.076.371.227.517.15.145.326.218.525.218h3.733l4.52-.129-1.728 1.54-9.767 9.783a.692.692 0 0 0-.232.518c0 .205.078.387.235.545a.74.74 0 0 0 .542.237.73.73 0 0 0 .527-.224l9.775-9.78 1.544-1.727-.143 4.188v4.065c0 .199.075.376.225.531.15.155.327.232.531.232.202 0 .38-.076.534-.228a.768.768 0 0 0 .23-.569Z"
                  fill="currentColor"
                />
              </svg>
            </span>
            <span class="shrink-0 text-sm text-neutral-300">2026</span>
          </div>
        </a>
        <div
          class="relative aspect-[2/1] overflow-hidden rounded-2xl border border-neutral-200 bg-white dark:border-neutral-700 dark:bg-neutral-900"
        >
          <video
            src="/slides.mp4"
            autoplay
            loop
            muted
            playsinline
            preload="auto"
            class="absolute inset-0 h-full w-full object-cover"
          ></video>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div
            class="relative aspect-square overflow-hidden rounded-2xl border border-neutral-200 bg-white dark:border-neutral-700 dark:bg-neutral-900"
          >
            <video
              src="/bento/glsl-distortion.mp4"
              autoplay
              loop
              muted
              playsinline
              preload="auto"
              class="absolute inset-0 h-full w-full object-cover"
            ></video>
          </div>
          <div
            class="relative aspect-square overflow-hidden rounded-2xl border border-neutral-200 bg-white dark:border-neutral-700 dark:bg-neutral-900"
          >
            <video
              src="/bento/radial-select.mp4"
              autoplay
              loop
              muted
              playsinline
              preload="auto"
              class="absolute inset-0 h-full w-full object-cover"
            ></video>
          </div>
        </div>
        <div
          class="relative aspect-[2/1] overflow-hidden rounded-2xl border border-neutral-200 bg-white dark:border-neutral-700 dark:bg-neutral-900"
        >
          <video
            src="/bento/round-and-round.mp4"
            autoplay
            loop
            muted
            playsinline
            preload="auto"
            class="absolute inset-0 h-full w-full object-cover"
          ></video>
        </div>
      </div>
    </div>
  </section>
</main>
