---
import Link from "./icons/link.astro";

const projects = [
  {
    label: "Vaayu",
    href: "vaayu.lol",
    description: "2025 · Tiny (<5kB), zero-config static site generator.",
  },
  {
    label: "kmenu",
    href: "kmenu.dev",
    description:
      "2022 · A versatile, accessible and animated ⌘K component for React. Combines elements of the greatest command menu implementations to provide the most intuitive, streamlined, and robust application navigation experience for users.",
  },
  {
    label: "Qursor",
    href: "qursor.harshsingh.me",
    description: "2021 · Plug n' play cursors for React.",
  },
  {
    label: "snip",
    href: "snip.tf",
    description: "2020 · Modern pastebin written in Actix.",
  },
  {
    label: "dots",
    href: "github.com/haaarshsingh/dots",
    description: "2020 · Pastel-themed i3wm and Arch Linux rice.",
  },
];

const socials = [
  {
    label: "h@harshsingh.me",
    href: "mailto:h@harshsingh.me",
  },
  {
    label: "X",
    href: "https://x.com/haaarshsingh",
  },
  {
    label: "GitHub",
    href: "https://github.com/haaarshsingh",
  },
  {
    label: "Linkedin",
    href: "https://www.linkedin.com/in/haaarshsingh",
  },
  {
    label: "CV",
    href: "/cv.pdf",
  },
];
---

<main>
  <section class="mt-12">
    <h2
      class="animate-intro mb-3 font-medium opacity-0 [animation-delay:0.35s]"
    >
      Where
    </h2>
    <div
      class="animate-intro relative h-fit w-fit overflow-hidden rounded-3xl opacity-0 [animation-delay:0.4s]"
    >
      <img
        src="/cloud.webp"
        width="390"
        height="347"
        alt=""
        draggable="false"
        class="animate-cloud absolute z-10 blur-sm"
      />
      <img
        src="/plane.webp"
        width="24"
        height="56"
        alt=""
        draggable="false"
        class="animate-plane absolute z-10 -translate-x-96 [animation-delay:5s]"
      />
      <img
        src="/plane-shadow.webp"
        width="24"
        height="24"
        alt=""
        draggable="false"
        class="animate-plane-shadow absolute z-10 -translate-x-96 [animation-delay:5s]"
      />
      <img
        width="500"
        height="250"
        src="/map.webp"
        alt="Map with marker east of Austin, TX"
        loading="eager"
        draggable="false"
        class="dark:hidden"
      />
      <img
        width="500"
        height="250"
        src="/map-dark.webp"
        alt="Map with marker east of Austin, TX"
        loading="eager"
        draggable="false"
        class="hidden dark:block"
      />
      <a
        href="https://en.wikipedia.org/wiki/Austin,_Texas"
        target="_blank"
        rel="noreferrer"
        class="exclude absolute right-0 bottom-0 mr-3 mb-3 rounded-md border border-neutral-300 bg-neutral-50 px-2 py-1.5 text-xs text-neutral-600 select-none dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-300"
        >Austin, TX</a
      >
      <div aria-hidden>
        <div
          class="animate-marker absolute top-[60%] left-[53%] h-6 w-6 rounded-full bg-blue-500"
        >
        </div>
        <div
          class="shadow-marker absolute top-[60%] left-[53%] h-6 w-6 -translate-x-1/2 -translate-y-1/2 rounded-full border-[3px] border-neutral-50 bg-blue-500"
        >
        </div>
      </div>
    </div>
  </section>
  <section class="mt-12">
    <h2 class="animate-intro mb-3 font-medium opacity-0 [animation-delay:0.4s]">
      Projects
    </h2>
    <ul
      class="animate-intro relative flex flex-col gap-y-4 opacity-0 [animation-delay:0.45s]"
    >
      {
        projects.map((project) => (
          <li>
            <a
              href={`https://${project.href}`}
              rel="noreferrer"
              target="_blank"
              class="flex w-fit items-center"
            >
              {project.label}
              <Link />
            </a>
            <p class="mt-1 leading-snug font-light text-neutral-500 dark:text-neutral-400">
              {project.description}
            </p>
            {project.label === "kmenu" && (
              <div class="mt-3 flex w-full items-center justify-between gap-[10px]">
                {[1, 2, 3].map((num) => (
                  <>
                    <img
                      src={`/kmenu/${num}.webp`}
                      alt=""
                      draggable="false"
                      class="kmenu-light w-[32%] object-contain dark:hidden"
                    />
                    <img
                      src={`/kmenu/${num}-dark.webp`}
                      alt=""
                      draggable="false"
                      class="kmenu-dark hidden w-[32%] object-contain dark:block"
                    />
                  </>
                ))}
              </div>
            )}
          </li>
        ))
      }
    </ul>
    <section class="animate-intro mt-12 opacity-0 [animation-delay:0.5s]">
      <h2 class="mb-3 font-medium">Connect</h2>
      <div class="flex flex-row flex-wrap items-center gap-x-1 gap-y-2">
        {
          socials.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noreferrer"
              class="exclude flex items-center rounded-full bg-neutral-200 px-3 py-1 text-sm transition-colors select-none hover:bg-neutral-300 dark:bg-neutral-800 dark:hover:bg-neutral-700"
            >
              {social.label}
              <Link />
            </a>
          ))
        }
      </div>
    </section>
  </section>
</main>
