---
import "../global.css";
import Footer from "./footer.astro";

type LayoutProps = {
  title?: string;
  description?: string;
  ogImage?: string;
  type?: "website" | "article";
  publishedTime?: string;
  noIndex?: boolean;
};

const {
  title = "Harsh Singh",
  description = "Harsh Singh is a software engineer based in Austin, Texas. Personal site, portfolio, and writing on systems, design, and tooling.",
  ogImage,
  type = "website",
  publishedTime,
  noIndex = false,
} = Astro.props as LayoutProps;

const SITE_URL = "https://www.harshsingh.me";
const PERSON_ID = `${SITE_URL}/#person`;
const WEBSITE_ID = `${SITE_URL}/#website`;

const isHome = Astro.url.pathname === "/" || Astro.url.pathname === "";
const pageTitle = isHome ? "Harsh Singh — Software Engineer" : `${title} | Harsh Singh`;
const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).href;

const resolvedOgImage =
  ogImage ||
  (title !== "Harsh Singh"
    ? `${SITE_URL}/api/og?title=${encodeURIComponent(title)}`
    : `${SITE_URL}/og.png`);

const robotsContent = noIndex
  ? "noindex, nofollow"
  : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": PERSON_ID,
  name: "Harsh Singh",
  alternateName: ["haaarshsingh", "Harsh"],
  url: SITE_URL,
  image: "https://github.com/haaarshsingh.png",
  jobTitle: "Software Engineer",
  worksFor: { "@type": "Organization", name: "Harsh Singh" },
  address: {
    "@type": "PostalAddress",
    addressLocality: "Austin",
    addressRegion: "TX",
    addressCountry: "US",
  },
  sameAs: [
    "https://x.com/haaarshsingh",
    "https://github.com/haaarshsingh",
    "https://www.linkedin.com/in/haaarshsingh",
    "https://www.youtube.com/@haaarshsingh",
    "https://instagram.com/dtx.singh",
  ],
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": WEBSITE_ID,
  url: SITE_URL,
  name: "Harsh Singh",
  description,
  inLanguage: "en-US",
  author: { "@id": PERSON_ID },
  publisher: { "@id": PERSON_ID },
};

const blogPostingSchema =
  type === "article"
    ? {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        headline: title,
        description,
        image: resolvedOgImage,
        ...(publishedTime ? { datePublished: publishedTime } : {}),
        author: { "@id": PERSON_ID },
        publisher: { "@id": PERSON_ID },
        mainEntityOfPage: { "@type": "WebPage", "@id": canonicalUrl },
        url: canonicalUrl,
      }
    : null;
---

<html lang="en">
  <head>
    <script is:inline>
      (() => {
        const navEntry = performance.getEntriesByType("navigation")[0];
        const isBackForward = navEntry && navEntry.type === "back_forward";
        const fromSameSite =
          document.referrer &&
          new URL(document.referrer).origin === location.origin;

        if (isBackForward || fromSameSite) {
          document.documentElement.classList.add("skip-intro");
        }
      })();

      const theme = (() => {
        if (typeof localStorage !== "undefined") {
          const stored = localStorage.getItem("theme");
          if (stored === "dark" || stored === "light") {
            return stored;
          }
        }
        if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
          return "dark";
        }
        return "light";
      })();

      if (theme === "dark") {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }

      if (typeof localStorage !== "undefined") {
        localStorage.setItem("theme", theme);
      }
    </script>
    <meta charset="utf-8" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=2, user-scalable=yes"
    />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#E5E5E5" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Harsh Singh"
      href="/rss.xml"
    />
    <meta name="author" content="Harsh Singh" />
    <link rel="author" href={SITE_URL} />
    <meta name="creator" content="Harsh Singh" />
    <meta name="publisher" content="Harsh Singh" />
    <meta
      name="keywords"
      content="Harsh Singh, harshsingh.me, haaarshsingh, software engineer, portfolio, Austin Texas, kmenu, qursor, dotfiles"
    />
    <meta name="robots" content={robotsContent} />
    <meta name="googlebot" content={robotsContent} />
    <meta name="category" content="technology" />
    <meta name="me" content="h@harshsingh.me" />

    <meta
      name="google-site-verification"
      content="VWhTtgTikPqvWIY4n2rlUj6Fe9YgkfFMEET3TM7Rce0"
    />
    <meta name="yandex-verification" content="cfc27cbb03eb0a9c" />

    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Harsh Singh" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content={isHome ? "Harsh Singh" : `${title} — Harsh Singh`}
    />

    {
      type === "article" && publishedTime && (
        <meta property="article:published_time" content={publishedTime} />
      )
    }
    {type === "article" && <meta property="article:author" content={SITE_URL} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@haaarshsingh" />
    <meta name="twitter:creator" content="@haaarshsingh" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />

    <link rel="dns-prefetch" href="https://lastfm.freetls.fastly.net" />
    <link
      rel="preconnect"
      href="https://lastfm.freetls.fastly.net"
      crossorigin
    />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(personSchema)}
    />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(websiteSchema)}
    />
    <script is:inline>
      console.log(
        `                                _____ \n             _    _            |___  |\n _ _ _ _ _ _| |  | |_ ___ ___ ___|  _|\n| | | | | | . |  |   | -_|  _| -_|_|  \n|_____|_  |___|  |_|_|___|_| |___|_|  \n      |___|                           `,
      );
      console.log(
        "This website is open-source at https://github.com/haaarshsingh/www",
      );
    </script>
    {
      blogPostingSchema && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(blogPostingSchema)}
        />
      )
    }

    <style is:global>
      .astro-code,
      .astro-code span {
        color: var(--shiki-light);
        background-color: transparent;
      }
      .astro-code {
        background-color: #f5f5f5 !important;
        border: 1px solid #e5e5e5;
      }
      .dark .astro-code,
      .dark .astro-code span {
        color: var(--shiki-dark);
      }
      .dark .astro-code {
        background-color: var(--shiki-dark-bg) !important;
        border: none;
      }
    </style>
  </head>
  <body>
    <div class="flex justify-center">
      <div
        class="xs:w-[500px] mt-16 flex min-h-screen w-[90vw] flex-col justify-between"
      >
        <slot />
        <Footer isHome={Astro.url.pathname === "/"} />
      </div>
    </div>
  </body>
</html>
