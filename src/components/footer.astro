---
const { isHome = false } = Astro.props;
---

<script>
  // Footer is below the fold. Wait for window.load, then idle, before firing.
  // Low fetch priority keeps it off Lighthouse's critical request chain.
  const loadLastVisitor = () => {
    fetch("/api/last-visitor", { priority: "low" } as RequestInit)
      .then((res) => res.json())
      .then((data) => {
        const lastVisitElement = document.querySelector(".last-visit");
        if (lastVisitElement) {
          lastVisitElement.textContent = data.result;
          lastVisitElement.classList.remove(
            "animate-pulse",
            "bg-neutral-200",
            "dark:bg-neutral-700",
            "h-4",
            "w-28",
            "mt-0.5",
            "rounded",
          );
        }
      })
      .catch(() => {});
  };

  const afterLoad = () => {
    if ("requestIdleCallback" in window) {
      window.requestIdleCallback(loadLastVisitor, { timeout: 3000 });
    } else {
      setTimeout(loadLastVisitor, 400);
    }
  };

  if (document.readyState === "complete") {
    setTimeout(afterLoad, 0);
  } else {
    window.addEventListener("load", afterLoad, { once: true });
  }
</script>

<script>
  const handleToggleClick = () => {
    const element = document.documentElement;
    element.classList.toggle("dark");

    const isDark = element.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  };

  document
    .getElementById("themeToggle")
    ?.addEventListener("click", handleToggleClick);

  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      document.getElementById("themeToggle")?.setAttribute("data-ready", "");
    });
  });
</script>

<footer
  class:list={[
    "mt-12 mb-16 flex items-center justify-between",
    isHome && "animate-intro opacity-0 [animation-delay:0.6s]",
  ]}
>
  <div>
    <p class="text-sm font-light text-neutral-500 dark:text-neutral-400">
      Made with <a
        href="https://astro.build/"
        target="_blank"
        rel="noreferrer"
        class="font-normal">Astro</a
      >
    </p>
    <p
      class="flex items-center text-sm font-light text-neutral-500 dark:text-neutral-400"
    >
      Last visit from <span
        class="last-visit mt-0.5 ml-1 inline-block h-4 w-28 animate-pulse rounded bg-neutral-200 dark:bg-neutral-700"
      ></span>
    </p>
  </div>
  <button
    id="themeToggle"
    aria-label="Toggle theme"
    class="flex size-6 items-center justify-center text-neutral-800 dark:text-neutral-200"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="theme-toggle-svg"
    >
      <mask id="moon-mask">
        <rect x="0" y="0" width="100%" height="100%" fill="white" />
        <circle class="mask-circle" r="9" fill="black" />
      </mask>
      <circle
        class="center-circle"
        fill="currentColor"
        cx="12"
        cy="12"
        mask="url(#moon-mask)"
      />
      <g class="sun-rays" stroke="currentColor">
        <line x1="12" y1="1" x2="12" y2="3" />
        <line x1="12" y1="21" x2="12" y2="23" />
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
        <line x1="1" y1="12" x2="3" y2="12" />
        <line x1="21" y1="12" x2="23" y2="12" />
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
      </g>
    </svg>
  </button>
</footer>

<style>
  .theme-toggle-svg {
    transform: rotate(40deg);
  }
  .center-circle {
    r: 9px;
  }
  .mask-circle {
    cx: 12px;
    cy: 4px;
  }
  .sun-rays {
    opacity: 0;
  }

  :global(.dark) .theme-toggle-svg {
    transform: rotate(90deg);
  }
  :global(.dark) .center-circle {
    r: 5px;
  }
  :global(.dark) .mask-circle {
    cx: 30px;
    cy: 0;
  }
  :global(.dark) .sun-rays {
    opacity: 1;
  }

  :global(#themeToggle[data-ready]) .theme-toggle-svg {
    transition: transform 750ms cubic-bezier(0.2, 1.3, 0.4, 1);
  }
  :global(#themeToggle[data-ready]) .center-circle {
    transition: r 750ms cubic-bezier(0.2, 1.3, 0.4, 1);
  }
  :global(#themeToggle[data-ready]) .mask-circle {
    transition:
      cx 750ms cubic-bezier(0.2, 1.3, 0.4, 1),
      cy 750ms cubic-bezier(0.2, 1.3, 0.4, 1);
  }
  :global(#themeToggle[data-ready]) .sun-rays {
    transition: opacity 500ms ease;
  }
</style>
