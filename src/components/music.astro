---
---

<div class="aspect-square w-full">
  <div
    id="music-skeleton"
    class="aspect-square w-full animate-pulse rounded-2xl bg-neutral-200 dark:bg-neutral-800"
  >
  </div>

  <a
    id="music-track"
    class="exclude group relative hidden aspect-square overflow-hidden rounded-2xl border border-neutral-200 transition-colors duration-300 dark:border-neutral-700"
    href="#"
    target="_blank"
    rel="noreferrer"
  >
    <div
      id="music-bg"
      class="absolute -inset-8 bg-cover bg-center blur-md"
      aria-hidden="true"
    >
    </div>
    <div class="absolute inset-0 bg-neutral-900/70"></div>
    <div class="relative flex h-full flex-col justify-end p-4">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="28"
        height="28"
        viewBox="0 0 75 75"
        aria-label="Spotify"
        class="absolute top-4 left-4"
      >
        <path
          d="M61.625,35.375c-12-7.125-32.062-7.875-43.5-4.312A3.439,3.439,0,1,1,16.062,24.5c13.313-3.938,35.25-3.187,49.125,5.063A3.624,3.624,0,0,1,66.5,34.437a3.929,3.929,0,0,1-4.875.938m-.375,10.5a2.825,2.825,0,0,1-3.937.938C47.188,40.625,31.812,38.75,20,42.5a2.847,2.847,0,1,1-1.688-5.437C32,32.937,48.875,35,60.5,42.125a2.647,2.647,0,0,1,.75,3.75m-4.5,10.313a2.228,2.228,0,0,1-3.188.75c-8.812-5.437-19.875-6.563-33-3.562a2.319,2.319,0,1,1-1.125-4.5C33.687,45.687,46.063,47,55.813,53a2.247,2.247,0,0,1,.938,3.188M39.5,2A37.5,37.5,0,1,0,77,39.5,37.514,37.514,0,0,0,39.5,2Z"
          transform="translate(-2 -2)"
          fill="#62dbbe"></path>
      </svg>

      <div
        id="music-cover-wrapper"
        class="absolute top-4 right-4 hidden h-20 w-20"
      >
        <img
          src="/disc.webp"
          alt=""
          draggable="false"
          class="absolute top-2 -left-6 h-16 w-16 animate-spin [animation-duration:4s] transition-[left] duration-200 ease-out group-hover:-left-7"
        />
        <img
          id="music-cover"
          alt=""
          draggable="false"
          class="relative h-20 w-20 rounded-lg object-cover shadow-lg"
        />
      </div>

      <div>
        <div class="flex items-center gap-1.5">
          <span class="flex h-3 items-center gap-[3px]">
            <span class="eq-bar" style="animation-duration:0.85s"></span>
            <span class="eq-bar" style="animation-duration:1.26s"></span>
            <span class="eq-bar" style="animation-duration:0.62s"></span>
          </span>
          <span id="music-status" class="text-xs font-medium text-[#62dbbe]">
            Last played
          </span>
        </div>
        <p
          id="music-title"
          class="mt-1 truncate text-base font-bold text-white"
        >
        </p>
        <p
          id="music-artist"
          class="truncate text-sm text-neutral-300"
        >
        </p>
      </div>
    </div>
  </a>

  <p
    id="music-empty"
    class="hidden text-sm font-light text-neutral-500 dark:text-neutral-400"
  >
    Nothing playing
  </p>
</div>

<script>
  type Rgb = { r: number; g: number; b: number };

  // Sample a representative accent color from album art: prefer saturated,
  // mid-lightness pixels so we get something close to the cover's brand color
  // rather than a muddy average.
  const extractAccentColor = (img: HTMLImageElement): Rgb | null => {
    try {
      const size = 32;
      const canvas = document.createElement("canvas");
      canvas.width = size;
      canvas.height = size;
      const ctx = canvas.getContext("2d");
      if (!ctx) return null;
      ctx.drawImage(img, 0, 0, size, size);
      const { data } = ctx.getImageData(0, 0, size, size);

      let bestR = 0;
      let bestG = 0;
      let bestB = 0;
      let bestScore = -1;
      let sumR = 0;
      let sumG = 0;
      let sumB = 0;
      let count = 0;

      for (let i = 0; i < data.length; i += 4) {
        const r = data[i] ?? 0;
        const g = data[i + 1] ?? 0;
        const b = data[i + 2] ?? 0;
        const a = data[i + 3] ?? 0;
        if (a < 200) continue;
        sumR += r;
        sumG += g;
        sumB += b;
        count++;
        const max = Math.max(r, g, b);
        const min = Math.min(r, g, b);
        const lightness = (max + min) / 2 / 255;
        if (lightness < 0.18 || lightness > 0.82) continue;
        const saturation = max === 0 ? 0 : (max - min) / max;
        const score = saturation * 2 + (1 - Math.abs(lightness - 0.5));
        if (score > bestScore) {
          bestScore = score;
          bestR = r;
          bestG = g;
          bestB = b;
        }
      }

      if (bestScore < 0 && count > 0) {
        bestR = Math.round(sumR / count);
        bestG = Math.round(sumG / count);
        bestB = Math.round(sumB / count);
      }

      return { r: bestR, g: bestG, b: bestB };
    } catch {
      return null;
    }
  };

  // Saturated colors on a near-black background read as glaring neon. Mix the
  // accent toward the dark surface so it reads as a tint, not a glow.
  const formatAccent = ({ r, g, b }: Rgb): string => {
    const isDark = document.documentElement.classList.contains("dark");
    if (!isDark) return `rgb(${r}, ${g}, ${b})`;
    const mix = 0.45; // weight of accent vs. background
    const bg = 23; // neutral-900-ish
    const dr = Math.round(r * mix + bg * (1 - mix));
    const dg = Math.round(g * mix + bg * (1 - mix));
    const db = Math.round(b * mix + bg * (1 - mix));
    return `rgb(${dr}, ${dg}, ${db})`;
  };

  const setBorderFromDataset = (track: HTMLElement) => {
    const r = Number(track.dataset.accentR);
    const g = Number(track.dataset.accentG);
    const b = Number(track.dataset.accentB);
    if (Number.isFinite(r) && Number.isFinite(g) && Number.isFinite(b)) {
      track.style.borderColor = formatAccent({ r, g, b });
    }
  };

  const applyAccent = (track: HTMLElement, src: string) => {
    const probe = new Image();
    probe.crossOrigin = "anonymous";
    probe.referrerPolicy = "no-referrer";
    probe.onload = () => {
      const accent = extractAccentColor(probe);
      if (!accent) return;
      track.dataset.accentR = String(accent.r);
      track.dataset.accentG = String(accent.g);
      track.dataset.accentB = String(accent.b);
      setBorderFromDataset(track);
    };
    probe.src = src;
  };

  // Re-apply the border whenever the theme toggle flips <html>.dark.
  const observeThemeChanges = (track: HTMLElement) => {
    const observer = new MutationObserver(() => setBorderFromDataset(track));
    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    });
  };

  const loadMusic = () => {
    fetch("/api/lastfm")
      .then((res) => res.json())
      .then((data) => {
        const skeleton = document.getElementById("music-skeleton")!;
        const track = document.getElementById("music-track")!;
        const empty = document.getElementById("music-empty")!;

        skeleton.classList.add("hidden");

        if (data.title) {
          const bg = document.getElementById("music-bg")!;
          const cover = document.getElementById(
            "music-cover",
          ) as HTMLImageElement;
          const coverWrapper = document.getElementById("music-cover-wrapper")!;
          if (data.albumArt) {
            bg.style.backgroundImage = `url(${data.albumArt})`;
            cover.src = data.albumArt;
            coverWrapper.classList.remove("hidden");
            applyAccent(track, data.albumArt);
            observeThemeChanges(track);
          }

          document.getElementById("music-title")!.textContent = data.title;
          document.getElementById("music-artist")!.textContent = data.artist;
          (track as HTMLAnchorElement).href = data.url;
          track.classList.remove("hidden");
          track.classList.add("block");

          if (data.isPlaying) {
            document.getElementById("music-status")!.textContent =
              "Now playing";
          }
        } else {
          empty.classList.remove("hidden");
        }
      })
      .catch(() => {
        document.getElementById("music-skeleton")!.classList.add("hidden");
        document.getElementById("music-empty")!.classList.remove("hidden");
      });
  };

  // Defer off the LCP critical chain. The skeleton covers the gap, and idle
  // callbacks usually fire within ~100ms after the page is interactive.
  if ("requestIdleCallback" in window) {
    window.requestIdleCallback(loadMusic, { timeout: 2000 });
  } else {
    setTimeout(loadMusic, 200);
  }
</script>

<style is:global>
  .eq-bar {
    width: 2px;
    height: 3px;
    border-radius: 9999px;
    background-color: #62dbbe;
    animation: playing 0.85s infinite ease;
  }

  @keyframes playing {
    0% {
      height: 3px;
    }
    50% {
      height: 12px;
    }
    to {
      height: 3px;
    }
  }
</style>
