---
import {
  isAuthenticated,
  isPasswordConfigured,
  listShortLinks,
  type ShortLink,
} from "../lib/shortener";

export const prerender = false;

const authed = isAuthenticated(Astro.cookies);
const configured = isPasswordConfigured();
const params = Astro.url.searchParams;
const loginError = params.get("error");
const createError = params.get("createError");
const created = params.get("created");
const editSlug = params.get("edit");
const editError = params.get("editError");
const updated = params.get("updated");
const deleted = params.get("deleted");

let links: ShortLink[] = [];
let listError: string | null = null;
if (authed) {
  try {
    links = await listShortLinks();
  } catch (err) {
    listError = err instanceof Error ? err.message : "Unable to load links.";
  }
}

const editing = editSlug ? links.find((l) => l.slug === editSlug) : null;

const origin = Astro.url.origin;
const formatDate = (ms: number): string =>
  ms ? new Date(ms).toISOString().replace("T", " ").slice(0, 16) + " UTC" : "—";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Shortener</title>
  </head>
  <body>
    <h1>URL Shortener</h1>

    {
      !configured && (
        <p>
          <strong>Not configured.</strong> Set <code>SHORTENER_PASSWORD</code>{" "}
          in the environment.
        </p>
      )
    }

    {
      !authed && configured && (
        <section>
          <h2>Log in</h2>
          {loginError && <p>Invalid password.</p>}
          <form method="POST" action="/api/shortener/login">
            <p>
              <label>
                Password:
                <input
                  type="password"
                  name="password"
                  autocomplete="current-password"
                  required
                />
              </label>
            </p>
            <p>
              <button type="submit">Log in</button>
            </p>
          </form>
        </section>
      )
    }

    {
      authed && (
        <>
          <section>
            <form method="POST" action="/api/shortener/logout">
              <button type="submit">Log out</button>
            </form>
          </section>

          {editing ? (
            <section>
              <h2>Edit link</h2>
              {editError && <p>Error: {editError}</p>}
              <form method="POST" action="/api/shortener/edit">
                <input type="hidden" name="slug" value={editing.slug} />
                <p>
                  <label>
                    Long URL:
                    <br />
                    <input
                      type="url"
                      name="url"
                      required
                      size={60}
                      value={editing.url}
                    />
                  </label>
                </p>
                <p>
                  <label>
                    Slug:
                    <br />
                    <input
                      type="text"
                      name="new_slug"
                      size={30}
                      value={editing.slug}
                    />
                  </label>
                </p>
                <p>
                  <button type="submit">Save</button>{" "}
                  <a href="/shortener">Cancel</a>
                </p>
              </form>
            </section>
          ) : (
            <section>
              <h2>New short link</h2>
              {createError && <p>Error: {createError}</p>}
              {created && (
                <p>
                  Created:{" "}
                  <a href={`/${created}`}>
                    {origin}/{created}
                  </a>
                </p>
              )}
              {updated && <p>Updated: {updated}</p>}
              {deleted && <p>Deleted: {deleted}</p>}
              <form method="POST" action="/api/shortener/create">
                <p>
                  <label>
                    Long URL:
                    <br />
                    <input
                      type="url"
                      name="url"
                      required
                      size={60}
                      placeholder="https://example.com/some/long/path"
                    />
                  </label>
                </p>
                <p>
                  <label>
                    Custom slug (optional):
                    <br />
                    <input
                      type="text"
                      name="slug"
                      size={30}
                      placeholder="my-link"
                    />
                  </label>
                </p>
                <p>
                  <button type="submit">Shorten</button>
                </p>
              </form>
            </section>
          )}

          <section>
            <h2>Links</h2>
            {listError && <p>Error loading links: {listError}</p>}
            {!listError && links.length === 0 && <p>No links yet.</p>}
            {!listError && links.length > 0 && (
              <table border="1" cellpadding="6" cellspacing="0">
                <thead>
                  <tr>
                    <th>Short URL</th>
                    <th>Original URL</th>
                    <th>Clicks</th>
                    <th>Created</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {links.map((link) => (
                    <tr>
                      <td>
                        <a href={`/${link.slug}`}>
                          {origin}/{link.slug}
                        </a>
                      </td>
                      <td>
                        <a href={link.url} rel="noreferrer">
                          {link.url}
                        </a>
                      </td>
                      <td>{link.clicks}</td>
                      <td>{formatDate(link.createdAt)}</td>
                      <td>
                        <a href={`?edit=${encodeURIComponent(link.slug)}`}>
                          Edit
                        </a>
                        {" | "}
                        <form
                          method="POST"
                          action="/api/shortener/delete"
                          style="display:inline"
                          onsubmit={`return confirm('Delete /${link.slug}?')`}
                        >
                          <input type="hidden" name="slug" value={link.slug} />
                          <button type="submit">Delete</button>
                        </form>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            )}
          </section>
        </>
      )
    }
  </body>
</html>
