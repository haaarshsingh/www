---
import Header from "../components/header.astro";
import Main from "../components/main.astro";
import Layout from "../components/layout.astro";
---

<Layout>
  <Header />
  <Main />
</Layout>

<script>
  // Fire-and-forget visitor logging. Defer off the critical request chain so it
  // doesn't compete with LCP, we never read the response.
  const ping = () => {
    try {
      fetch("/api/locate", {
        method: "GET",
        keepalive: true,
        cache: "no-store",
      }).catch(() => {});
    } catch {}
  };

  const schedule = () => {
    if ("requestIdleCallback" in window) {
      window.requestIdleCallback(ping, { timeout: 4000 });
    } else {
      setTimeout(ping, 1500);
    }
  };

  if (document.readyState === "complete") {
    schedule();
  } else {
    window.addEventListener("load", schedule, { once: true });
  }
</script>
