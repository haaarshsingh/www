---
import Header from "../components/header.astro";
import Main from "../components/main.astro";
import Layout from "../components/layout.astro";
---

<Layout>
  <Header />
  <Main />
</Layout>

<script>
  // Fire-and-forget visitor logging. Run only after the load event and at low
  // fetch priority so Lighthouse doesn't classify it as part of the critical
  // request chain. The response is never read.
  const ping = () => {
    try {
      fetch("/api/locate", {
        method: "GET",
        keepalive: true,
        cache: "no-store",
        priority: "low",
      } as RequestInit).catch(() => {});
    } catch {}
  };

  const afterLoad = () => {
    if ("requestIdleCallback" in window) {
      window.requestIdleCallback(ping, { timeout: 4000 });
    } else {
      setTimeout(ping, 1500);
    }
  };

  if (document.readyState === "complete") {
    setTimeout(afterLoad, 0);
  } else {
    window.addEventListener("load", afterLoad, { once: true });
  }
</script>
